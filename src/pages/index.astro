---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { createDesign } from "@kondeio/kdf";
import starterTokens from "../../designs/starter.json";

const d = createDesign(starterTokens);
---

<Layout title="KDF - The Ultimate JSON Design Engine">
  <Navbar />
  
  <main data-kdf="layout.main" class={d("layout.main")}>
    <section data-kdf="hero.section" class={d("hero.section")}>
      <div data-kdf="hero.bg" class={d("hero.bg")}></div>
      
      <div data-kdf="hero.badge" class={d("hero.badge")}>
        <svg data-kdf="hero.badgeIcon" class={d("hero.badgeIcon")} width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z"/>
        </svg>
        KDF v0.1.3 is out now
      </div>
      
      <h1 data-kdf="hero.title" class={d("hero.title")}>
        Design as <span data-kdf="hero.titleHighlight" class={d("hero.titleHighlight")}>Data</span>, <br/>Rendered Anywhere.
      </h1>
      
      <p data-kdf="hero.subtitle" class={d("hero.subtitle")}>
        The first truly framework-agnostic design engine. Write your design system as pure JSON tokens and deploy it to Astro, Next.js, or raw HTML with zero CSS bloat.
      </p>
      
      <div data-kdf="hero.actions" class={d("hero.actions")}>
        <a data-kdf="btn.primary" href="https://github.com/KondeIO/kdf/blob/main/docs/doc.md" class={d("btn.primary")} target="_blank" rel="noopener noreferrer">
          Get Started
          <svg data-kdf="btn.primaryIcon" class={d("btn.primaryIcon")} width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a data-kdf="btn.outline" href="https://playground.konde.io/" class={d("btn.outline")} target="_blank" rel="noopener noreferrer">
          Open Playground
        </a>
      </div>
    </section>
    
    <section data-kdf="grid.features" class={d("grid.features")}>
      <div data-kdf="card.feature" class={d("card.feature")}>
        <div data-kdf="card.icon" class={d("card.icon")}>
          <svg data-kdf="card.iconSvg" class={d("card.iconSvg")} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          </svg>
        </div>
        <h3 data-kdf="card.title" class={d("card.title")}>JSON Driven</h3>
        <p data-kdf="card.desc" class={d("card.desc")}>
          Your complete design system—colors, spacing, components, and animations—lives in a structured, typed JSON dictionary.
        </p>
      </div>
      
      <div data-kdf="card.feature" class={d("card.feature")}>
        <div data-kdf="card.icon" class={d("card.icon")}>
          <svg data-kdf="card.iconSvg" class={d("card.iconSvg")} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <h3 data-kdf="card.title" class={d("card.title")}>Framework Agnostic</h3>
        <p data-kdf="card.desc" class={d("card.desc")}>
          No Tailwind dependency required. Build with Astro, React, Vue, or Vanilla JS. The KDF engine maps tokens directly to your chosen renderer.
        </p>
      </div>
      
      <div data-kdf="card.feature" class={d("card.feature")}>
        <div data-kdf="card.icon" class={d("card.icon")}>
          <svg data-kdf="card.iconSvg" class={d("card.iconSvg")} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
          </svg>
        </div>
        <h3 data-kdf="card.title" class={d("card.title")}>Extreme Performance</h3>
        <p data-kdf="card.desc" class={d("card.desc")}>
          Server-rendered design tokens output standard inline CSS classes. Zero Flash of Unstyled Content (FOUC). Native DOM performance.
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>

<style is:global>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
